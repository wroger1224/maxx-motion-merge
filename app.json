{
  "expo": {
    "name": "maxx-motion",
    "slug": "maxx-motion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "maxx-motion",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maxxpotential.maxxmotion",
      "infoPlist": {
        "NSHealthShareUsageDescription": "This app requires access to your health data to track fitness metrics and provide personalized insights.",
        "NSHealthUpdateUsageDescription": "This app requires permission to write health data for tracking your fitness activities."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.maxxpotential.maxxmotion"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-health-connect",
        {
          "healthConnectPermissions": [
            "READ_STEPS",
            "WRITE_STEPS",
            "READ_DISTANCE",
            "WRITE_DISTANCE",
            "READ_HEART_RATE",
            "WRITE_HEART_RATE",
            "READ_EXERCISE",
            "WRITE_EXERCISE",
            "READ_CALORIES",
            "WRITE_CALORIES"
          ]
        }
      ],
			[
				"expo-build-properties",
				{
					"android": {
						"minSdkVersion": 26
					}
				}
			]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "310c2824-96b9-4a0d-913d-aa279d98c378"
      }
    }
  }
}
