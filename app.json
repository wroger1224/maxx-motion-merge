{
  "expo": {
    "name": "maxx-motion",
    "slug": "maxx-motion",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "maxx-motion",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.maxxpotential.maxxmotion2",
      "infoPlist": {
        "NSHealthShareUsageDescription": "This app requires access to your health data to track fitness metrics and provide personalized insights.",
        "NSHealthUpdateUsageDescription": "This app requires permission to write health data for tracking your fitness activities.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.maxxpotential.maxxmotion2",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "maxx-motion"
            },
            {
              "scheme": "com.maxxpotential.maxxmotion2"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff"
        }
      ],
      [
        "expo-health-connect",
        {
          "healthConnectPermissions": [
            "READ_STEPS",
            "WRITE_STEPS",
            "READ_DISTANCE",
            "WRITE_DISTANCE",
            "READ_HEART_RATE",
            "WRITE_HEART_RATE",
            "READ_EXERCISE",
            "WRITE_EXERCISE",
            "READ_CALORIES",
            "WRITE_CALORIES"
          ]
        }
      ],
      [
        "react-native-health",
        {
          "healthSharePermission": "This app requires access to your health data to track fitness metrics and provide personalized insights.",
          "healthUpdatePermission": "This app requires permission to write health data for tracking your fitness activities."
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 26
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "7b35374a-38fd-4683-8ea4-4c5d7a5ff070"
      }
    },
    "owner": "maxx-motion"
  }
}
